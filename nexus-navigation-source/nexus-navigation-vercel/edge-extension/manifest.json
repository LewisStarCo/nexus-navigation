{
  "manifest_version": 3,
  "name": "Nexus Save",
  "version": "1.0.0",
  "description": "在 Microsoft Edge 中把当前网页直接保存到 Nexus 分类、未归类或临时网页。",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://nexus-navigation.vercel.app/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "保存到 Nexus",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://nexus-navigation.vercel.app/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
